# Copy to .env and fill in. NEVER commit the real .env file.
# In GitHub, set these as repository Actions secrets instead.

# --- Outgoing mail (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-app-password
FROM_EMAIL=you@example.com
FROM_NAME=Your Name
REPLY_TO=you@example.com

# --- Reply tracking (IMAP) ---
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=you@example.com
IMAP_PASS=your-app-password
IMAP_FOLDER=INBOX

# --- Event details (used to personalize emails) ---
EVENT_NAME=The Manhattan Mix: A Craft Cocktail Evening
EVENT_DATE=October 24, 2026
EVENT_CITY=New York, NY
EVENT_VENUE=The Foundry, Long Island City
EVENT_ATTENDANCE=250
EVENT_AUDIENCE=hospitality professionals, food & beverage press, and cocktail enthusiasts
EVENT_WEBSITE=https://example.com/cocktail-event

# --- Sender / organization identity (CAN-SPAM requires a real address) ---
ORGANIZER_NAME=Your Name
ORGANIZER_TITLE=Event Director
ORGANIZER_ORG=Your Organization
ORGANIZER_PHONE=+1 (555) 123-4567
PHYSICAL_ADDRESS=123 Example Street, Suite 100, New York, NY 10001
OPT_OUT_EMAIL=unsubscribe@example.com

# --- Sending controls ---
SEND_THROTTLE_SECONDS=8
